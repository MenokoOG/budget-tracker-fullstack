# PostgreSQL (used by both docker-compose and the api package)
POSTGRES_USER=budget
POSTGRES_PASSWORD=budget
POSTGRES_DB=budget_tracker
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Host-side port for connecting via psql/GUI tools (container-to-container still uses 5432)
POSTGRES_HOST_PORT=5433

# Convenience var the api reads directly (preferred over the discrete vars above)
DATABASE_URL=postgres://budget:budget@postgres:5432/budget_tracker

# API
API_PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Frontend (Vite picks these up at build time)
VITE_API_URL=http://localhost:3000
