FROM node:20-alpine

WORKDIR /app

# Install workspace root deps first (better cache)
COPY package.json package-lock.json* ./
COPY packages/api/package.json packages/api/

RUN npm install --workspace=@budget-tracker/api --include-workspace-root

COPY packages/api ./packages/api

WORKDIR /app/packages/api

EXPOSE 3000

CMD ["npm", "run", "dev"]
